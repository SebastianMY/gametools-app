# Game Companion — Environment Variables
#
# This app is fully offline and requires no environment variables for v1.0.
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# The .env file is git-ignored. Never commit secrets to the repository.
#
# ---------------------------------------------------------------------------
# EAS / Expo (optional — only needed for production builds via EAS CLI)
# ---------------------------------------------------------------------------
#
# EXPO_TOKEN=
#   Your Expo personal access token for CI/CD EAS builds.
#   Generate one at: https://expo.dev/accounts/[username]/settings/access-tokens
#
# EXPO_TOKEN=

# ---------------------------------------------------------------------------
# Future use (reserved for v1.1+ cloud sync feature, not active in v1.0)
# ---------------------------------------------------------------------------
#
# API_BASE_URL=
# API_KEY=
